{
  "name": "ongo",
  "version": "2.0.0",
  "private": true,
  "description": "OnGo — AI Business Operating Platform (Founder Command Center)",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @ongo/db generate",
    "db:migrate": "pnpm --filter @ongo/db migrate",
    "db:seed": "pnpm --filter @ongo/db seed",
    "db:studio": "pnpm --filter @ongo/db studio",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
