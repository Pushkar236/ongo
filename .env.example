# ─────────────────────────────────────────────────────────────────────────
# OnGo platform — environment. Copy to `.env` (gitignored) and fill in.
# Used by: docker-compose, packages/db (Prisma), apps/api (NestJS config).
# ─────────────────────────────────────────────────────────────────────────

# Postgres (docker-compose reads these)
POSTGRES_USER=ongo
POSTGRES_PASSWORD=ongo
POSTGRES_DB=ongo
# Use 5433 if you already run a native Postgres on the default 5432.
POSTGRES_PORT=5433
REDIS_PORT=6379

# Database connection (Prisma + API). Host-side: localhost. In-container: postgres.
DATABASE_URL=postgresql://ongo:ongo@localhost:5433/ongo?schema=public
REDIS_URL=redis://localhost:6379

# API
API_PORT=3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# JWT secrets — generate strong random values for any shared/prod environment.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed founder credentials (optional overrides)
SEED_FOUNDER_EMAIL=founder@ongo.ai
SEED_FOUNDER_PASSWORD=OnGoFounder!2026

# Dashboard → API base URL (apps/dashboard)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# AI agents (Phase 2). Leave ANTHROPIC_API_KEY blank to use the mock runner.
# Set a REAL metered API key (sk-ant-api…) from console.anthropic.com to run
# live LLM-backed agents. A Claude Code / claude.ai subscription token
# (sk-ant-oat…) is NOT an API key and is rejected on purpose.
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-8

# ─── FREE live agents (no Anthropic billing) ──────────────────────────────
# The Brain talks to any OpenAI-compatible API. Get a FREE key (no credit card)
# and set all three. Examples:
#   Groq   → LLM_BASE_URL=https://api.groq.com/openai/v1
#            LLM_MODEL=llama-3.3-70b-versatile      (key: console.groq.com)
#   Gemini → LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#            LLM_MODEL=gemini-2.0-flash             (key: aistudio.google.com)
# Selection order: a real sk-ant-api key wins; else LLM_* ; else mock.
LLM_PROVIDER=groq
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ─── Autonomy engine (the 24/7 loop) ──────────────────────────────────────
# Off by default. Set AUTONOMY_ENABLED=true to wake the engine on an interval.
# Runs only while the API process is alive — for true 24/7, host the API on a
# container platform (Railway / Render / Fly), not a laptop or Vercel.
AUTONOMY_ENABLED=false
AUTONOMY_INTERVAL_MS=900000

# Project incubator: auto-create a NEW repo from a discovered opportunity each
# cycle. Off by default (the founder can trigger one anytime via POST
# /autonomy/incubate). New repos are PRIVATE until you make them public, then
# they appear on the showcase automatically. Capped by AUTONOMY_INCUBATOR_MAX.
AUTONOMY_INCUBATOR=false
AUTONOMY_INCUBATOR_MAX=3

# ─── GitHub maintenance ───────────────────────────────────────────────────
# A fine-grained PAT (or App token) with repo read (+ issues/PR write once you
# want the engine to act). Comma-separated owner/repo list to maintain.
GITHUB_TOKEN=
GITHUB_REPOS=
GITHUB_STALE_DAYS=30

# ─── Public showcase (GitHub → website, NO token required) ─────────────────
# The autonomy engine syncs this user's public repos into Projects, and the
# marketing site renders the featured ones automatically. Uses the public
# GitHub API, so it works with zero credentials.
GITHUB_USER=Pushkar236
GITHUB_SHOWCASE=true
GITHUB_SHOWCASE_MAX=12
GITHUB_SHOWCASE_INCLUDE_FORKS=false

# apps/web → which OnGo Brain to read the showcase from. Defaults to the live
# Render backend, so the public site needs no extra config.
ONGO_API_URL=https://ongo-brain.onrender.com/api/v1
