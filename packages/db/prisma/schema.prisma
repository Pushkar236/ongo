// OnGo Brain — central data model for the AI Business Operating Platform.
// Every agent action, approval, and audit record lives here. The Brain
// orchestrator (apps/api) is the only writer of activity_logs + approvals.

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum Role {
  FOUNDER
  ADMIN
  OPERATOR
  AGENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AgentType {
  RESEARCH
  PRODUCT_MANAGER
  ARCHITECT
  DEVELOPER
  QA
  DEVOPS
  DOCUMENTATION
}

enum AgentStatus {
  IDLE
  WORKING
  PAUSED
  OFFLINE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectType {
  INTERNAL
  CLIENT
  SAAS
  AUTOMATION
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DeploymentStatus {
  NONE
  QUEUED
  BUILDING
  LIVE
  FAILED
  ROLLED_BACK
}

enum ActorType {
  AGENT
  HUMAN
  SYSTEM
}

enum CompetitionLevel {
  LOW
  MEDIUM
  HIGH
}

enum OpportunityStatus {
  NEW
  REVIEWING
  APPROVED
  REJECTED
  CONVERTED
}

enum CustomerStatus {
  LEAD
  ACTIVE
  CHURNED
}

enum LeadType {
  WEBSITE
  AUTOMATION
  SAAS
  OTHER
}

enum LeadStatus {
  NEW
  QUALIFIED
  ESTIMATED
  CONVERTED
  REJECTED
}

enum RevenueType {
  ONE_TIME
  RECURRING
  MILESTONE
}

// Human-in-the-loop tiers — see Brain ApprovalPolicy.
enum ApprovalLevel {
  AUTO // L1 — executes immediately, logged
  SUGGESTED // L2 — executes but surfaced for review
  MANDATORY // L3 — blocked until a human approves
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

// ─────────────────────────────── Models ───────────────────────────────

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(OPERATOR)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  decidedApprovals Approval[]     @relation("ApprovalDecidedBy")
  notifications    Notification[]

  @@map("users")
}

model Agent {
  id           String      @id @default(cuid())
  name         String
  type         AgentType
  role         String
  description  String?
  permissions  String[] // action types this agent may request (deny-by-default)
  status       AgentStatus @default(IDLE)
  memory       Json        @default("{}")
  lastActiveAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tasks              Task[]
  requestedApprovals Approval[]    @relation("ApprovalRequestedBy")
  opportunities      Opportunity[]

  @@map("agents")
}

model Project {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  description      String?
  status           ProjectStatus    @default(PLANNING)
  type             ProjectType      @default(INTERNAL)
  repoUrl          String?
  deploymentStatus DeploymentStatus @default(NONE)
  revenue          Decimal          @default(0) @db.Decimal(12, 2)

  // ── Public showcase fields (rendered on the OnGo marketing site) ──────
  tagline      String? // short one-liner for the card
  liveUrl      String? // deployed/demo URL (GitHub homepage)
  imageUrl     String? // optional screenshot; null → gradient fallback
  tech         String[]  @default([]) // language + topics, for badges
  stars        Int       @default(0)
  featured     Boolean   @default(false) // only featured projects are public
  source       String    @default("manual") // manual | github-sync | incubated
  pushedAt     DateTime? // last push on the source repo
  lastSyncedAt DateTime? // last time the GitHub sync touched this row
  devStep      Int       @default(0) // how many build steps the dev agent has committed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks        Task[]
  repositories Repository[]
  deployments  Deployment[]
  revenues     Revenue[]

  @@index([featured])
  @@map("projects")
}

model Task {
  id              String     @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus @default(PENDING)
  priority        Priority   @default(MEDIUM)
  payload         Json       @default("{}")
  result          Json?
  projectId       String?
  assignedAgentId String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedAgent Agent?   @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assignedAgentId])
  @@map("tasks")
}

model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  steps       Json           @default("[]")
  status      WorkflowStatus @default(DRAFT)
  trigger     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("workflows")
}

model Repository {
  id            String   @id @default(cuid())
  projectId     String
  provider      String   @default("github")
  url           String
  defaultBranch String   @default("main")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("repositories")
}

model Deployment {
  id          String           @id @default(cuid())
  projectId   String
  environment String           @default("production")
  status      DeploymentStatus @default(QUEUED)
  url         String?
  commitSha   String?
  deployedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("deployments")
}

// Append-only audit trail. Nothing happens in the platform without a record.
model ActivityLog {
  id        String    @id @default(cuid())
  actorType ActorType
  actorId   String?
  actorName String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now())

  @@index([actorType, actorId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Opportunity {
  id             String            @id @default(cuid())
  title          String
  market         String
  description    String?
  demandScore    Int               @default(0) // 0-100
  estRevenue     Decimal           @default(0) @db.Decimal(12, 2)
  competition    CompetitionLevel  @default(MEDIUM)
  recommendation String?
  status         OpportunityStatus @default(NEW)
  sourceAgentId  String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  sourceAgent Agent? @relation(fields: [sourceAgentId], references: [id], onDelete: SetNull)
  leads       Lead[]

  @@map("opportunities")
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  email     String
  company   String?
  status    CustomerStatus @default(LEAD)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("customers")
}

model Lead {
  id            String     @id @default(cuid())
  source        String     @default("marketplace")
  type          LeadType   @default(WEBSITE)
  request       Json       @default("{}")
  contactName   String?
  contactEmail  String?
  status        LeadStatus @default(NEW)
  estimate      Decimal?   @db.Decimal(12, 2)
  opportunityId String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)

  @@map("leads")
}

model Revenue {
  id         String      @id @default(cuid())
  projectId  String?
  amount     Decimal     @db.Decimal(12, 2)
  currency   String      @default("INR")
  type       RevenueType @default(ONE_TIME)
  note       String?
  recordedAt DateTime    @default(now())
  createdAt  DateTime    @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("revenue")
}

// Human-in-the-loop gate. The Brain creates these; humans (or AUTO policy) resolve them.
model Approval {
  id                 String         @id @default(cuid())
  actionType         String
  title              String
  level              ApprovalLevel
  riskLevel          RiskLevel      @default(LOW)
  status             ApprovalStatus @default(PENDING)
  payload            Json           @default("{}")
  impactAnalysis     String?
  requestedByAgentId String?
  decidedByUserId    String?
  decidedAt          DateTime?
  decisionNote       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  requestedByAgent Agent? @relation("ApprovalRequestedBy", fields: [requestedByAgentId], references: [id], onDelete: SetNull)
  decidedBy        User?  @relation("ApprovalDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([level])
  @@map("approvals")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("info")
  title     String
  body      String?
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
